{
  "name": "postpilot",
  "displayName": "PostPilot for X",
  "version": "0.6.10",
  "description": "Score every X post as you type — AI rewrites, thread scoring, voice coaching, and a hook library that learns what works for you.",
  "author": "PostPilot",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "plasmo": "~0.90.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.1",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://x.com/*",
      "https://twitter.com/*",
      "https://api.lemonsqueezy.com/*",
      "https://api.anthropic.com/*"
    ]
  }
}
